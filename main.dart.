// DATABASE HELPER = BUKU CATATAN PACE 📖
class DatabaseHelper {
  static final DatabaseHelper instance = DatabaseHelper._init();
  static Database? _database;
  DatabaseHelper._init();

  Future<Database> get database async {
    if (_database!= null) return _database!;
    _database = await _initDB('kasir_wamena.db');
    return _database!;
  }

  Future<Database> _initDB(String filePath) async {
    final dbPath = await getDatabasesPath();
    final path = join(dbPath, filePath);
    return await openDatabase(path, version: 1, onCreate: _createDB);
  }

  Future _createDB(Database db, int version) async {
    await db.execute('''
      CREATE TABLE barang (
        barcode TEXT PRIMARY KEY,
        nama TEXT NOT NULL,
        harga INTEGER NOT NULL
      )
    ''');
    await db.execute('''
      CREATE TABLE transaksi (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        jenis TEXT NOT NULL,
        barcode TEXT NOT NULL,
        nama TEXT NOT NULL,
        jumlah INTEGER NOT NULL,
        harga INTEGER NOT NULL,
        tanggal TEXT NOT NULL
      )
    ''');
  }

  Future<int> tambahBarang(String barcode, String nama, int harga) async {
    final db = await instance.database;
    return await db.insert('barang', {'barcode': barcode, 'nama': nama, 'harga': harga}, conflictAlgorithm: ConflictAlgorithm.replace);
  }

  Future<Map?> cariBarang(String barcode) async {
    final db = await instance.database;
    final result = await db.query('barang', where: 'barcode =?', whereArgs: [barcode]);
    return result.isNotEmpty? result.first : null;
  }

  Future<List<Map>> getAllBarang() async {
    final db = await instance.database;
    return await db.query('barang');
  }

  Future<int> tambahTransaksi(String jenis, String barcode, String nama, int jumlah, int harga, String tanggal) async {
    final db = await instance.database;
    return await db.insert('transaksi', {
      'jenis': jenis, 'barcode': barcode, 'nama': nama,
      'jumlah': jumlah, 'harga': harga, 'tanggal': tanggal
    });
  }

  Future<List<Map>> getTransaksiHarian(String tanggal) async {
    final db = await instance.database;
    return await db.query('transaksi', where: 'tanggal LIKE?', whereArgs: ['$tanggal%']);
  }

  Future<List<Map>> getTransaksiBulanan(String bulan) async {
    final db = await instance.database;
    return await db.query('transaksi', where: 'tanggal LIKE?', whereArgs: ['$bulan%']);
  }
}

